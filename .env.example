# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Legacy format (still supported until late 2026)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# JWT Secret Key for Session Management
# Generate a secure random string for production
JWT_SECRET_KEY=your-very-secure-random-string-here-minimum-32-characters

# Backend only - Service Role Key (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Logging
# Values: error | warn | info | debug
# Default: warn (production), debug (dev). Optional override.
LOG_LEVEL=debug

# Gated integration tests — set to "1" to run against the linked Supabase
# project. Each variable gates a different suite; combine as needed.
# SUPABASE_RPC_CONCURRENCY_TESTS=1   # lib/finance/__tests__/rpc-concurrency.test.ts
# SUPABASE_RLS_TESTS=1               # lib/finance/__tests__/rls-isolation.test.ts
# SUPABASE_API_TESTS=1               # lib/__tests__/api-regressions.test.ts + lib/api/__tests__/with-auth.test.ts
# SUPABASE_TRIGGER_TESTS=1           # lib/__tests__/trigger-behavior.test.ts
# SUPABASE_FINANCE_TESTS=1           # lib/finance/__tests__/financial-data.test.ts
# SUPABASE_RECAP_TESTS=1             # app/api/monthly-recap/process-step1/__tests__/route.integration.test.ts