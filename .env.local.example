# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-here

# New format (preferred - available in preview since June 2025)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# Legacy format (still supported until late 2026)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Backend only (if needed later)
# SUPABASE_SECRET_KEY=sb_secret_your-secret-key-here